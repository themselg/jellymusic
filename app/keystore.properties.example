# Release signing — TEMPLATE. Copy this file to `app/keystore.properties` (which is gitignored)
# and fill in your own values. The repo ships no signing key or passwords, so to produce a signed
# release APK you create your own keystore from scratch:
#
#   keytool -genkeypair -v \
#     -keystore app/jellymusic-release.keystore \
#     -alias <your-alias> -keyalg RSA -keysize 2048 -validity 10000
#
# Then point this file at it. Debug builds need none of this (they use the auto-generated
# debug keystore), so cloning + testing works with zero setup.

# Path to the keystore, relative to the :app module directory.
storeFile=jellymusic-release.keystore
storePassword=CHANGE_ME
keyAlias=CHANGE_ME
keyPassword=CHANGE_ME
